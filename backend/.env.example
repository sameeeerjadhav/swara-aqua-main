PORT=5000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=swara_aqua
# Set to false on Hostinger shared hosting (no SSL on localhost MySQL)
DB_SSL=false
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this
JWT_REFRESH_EXPIRES_IN=7d
# Comma-separated — include all domains that serve the frontend
FRONTEND_URL=http://localhost:5173,https://swaraaqua.labxco.in,https://your-subdomain.hostingersite.com

# IMPORTANT: Change the default admin password after first login!
# Default admin: phone=0000000000, password=admin123
# Change it via Admin → Profile → Change Password immediately after deployment.

# Firebase Admin SDK — choose ONE method (recommended: JSON file for Hostinger)
#
# METHOD A (recommended on Hostinger — hPanel env vars max 255 chars):
# 1. Firebase Console → Service accounts → Generate new private key → download JSON
# 2. Upload as backend/config/firebase-service-account.json (via File Manager / FTP)
# 3. In hPanel Node.js env, add ONLY this short variable:
FIREBASE_SERVICE_ACCOUNT_PATH=config/firebase-service-account.json
#
# METHOD B (local dev — paste full key in backend/.env file, NOT hPanel UI):
# FIREBASE_PROJECT_ID=waterdelivery-a2126
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@waterdelivery-a2126.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# Razorpay (from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx